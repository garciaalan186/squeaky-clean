#!/usr/bin/env bash
# pre-commit hook: scan staged content for API keys / secret material.
#
# Install:
#   cp scripts/pre-commit-secret-scan .git/hooks/pre-commit
#   chmod +x .git/hooks/pre-commit
#
# Bypass (emergency only):
#   SECRET_SCAN_BYPASS=1 git commit ...
#
# What it does:
#   1. Refuses staged files with blocklisted names (.env, *.pem, id_rsa, ...)
#   2. Runs scripts/scan_for_secrets.py over each staged file's working-tree
#      contents, reporting file + line on any high-entropy / known-format hit.
#   3. Exits non-zero on any hit. Honors SECRET_SCAN_BYPASS=1.
set -euo pipefail

if [[ "${SECRET_SCAN_BYPASS:-}" == "1" ]]; then
  echo "[pre-commit] secret scan BYPASSED via SECRET_SCAN_BYPASS=1" >&2
  exit 0
fi

REPO_ROOT="$(git rev-parse --show-toplevel)"
SCANNER="${REPO_ROOT}/scripts/scan_for_secrets.py"
if [[ ! -f "${SCANNER}" ]]; then
  SCANNER="${REPO_ROOT}/clean-agent-workflow/scripts/scan_for_secrets.py"
fi

mapfile -t STAGED < <(git diff --cached --name-only --diff-filter=ACM)
if [[ ${#STAGED[@]} -eq 0 ]]; then
  exit 0
fi

EXIT=0
for f in "${STAGED[@]}"; do
  full="${REPO_ROOT}/${f}"
  [[ -f "${full}" ]] || continue
  if ! python3 "${SCANNER}" "${full}" >/dev/null 2>/tmp/secret-scan-$$; then
    echo "[pre-commit] secrets detected in: ${f}" >&2
    cat /tmp/secret-scan-$$ >&2
    EXIT=1
  fi
done
rm -f /tmp/secret-scan-$$

if [[ ${EXIT} -ne 0 ]]; then
  echo "[pre-commit] aborting commit. Override with SECRET_SCAN_BYPASS=1." >&2
fi
exit ${EXIT}
