{
  "schema_version": "v1",
  "category": "rest_server_handler",
  "technology": "axum",
  "version_pin": "axum==0.7.0",
  "language": "rust",
  "install": {"manager": "cargo", "package": "axum==0.7"},
  "imports": {
    "primary": "use axum::{Json, Router};",
    "types": ["use axum::routing::post;", "use axum::http::StatusCode;", "use serde_json::Value;"]
  },
  "client_construction": {
    "code": "let app = Router::new();",
    "is_async": true,
    "thread_safe": true,
    "dependencies": []
  },
  "primary_operations": [
    {
      "name": "handle",
      "signature": "(Json(payload): Json<Value>) -> Result<Json<Value>, StatusCode>",
      "sdk_call": "Ok(Json(payload))",
      "error_types": ["axum::http::StatusCode"],
      "idempotency": "non_idempotent",
      "retry_policy": "none"
    }
  ],
  "auth": {"method": "none"},
  "code_style_notes": [
    "Router::new().route(\"/\", post(handle)) registers the handler",
    "axum::serve(listener, app) runs the server in tokio"
  ],
  "allowed_doc_origins": ["https://docs.rs/axum/"]
}
