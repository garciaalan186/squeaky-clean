{
  "schema_version": "v1",
  "category": "rest_server_handler",
  "technology": "fastapi",
  "version_pin": "fastapi==0.110",
  "language": "python",
  "install": {"manager": "pip", "package": "fastapi>=0.110"},
  "imports": {
    "primary": "from fastapi import HTTPException",
    "types":   ["from typing import Any"]
  },
  "client_construction": {
    "code": "self._use_case = use_case",
    "is_async": false,
    "thread_safe": true,
    "dependencies": ["use_case"]
  },
  "primary_operations": [
    {
      "name": "handle",
      "signature": "(payload: dict[str, Any]) -> dict[str, Any]",
      "sdk_call": "result = self._use_case.execute(payload); return {'status': 'ok', 'data': result}",
      "error_types": ["HTTPException", "ValueError"],
      "idempotency": "conditional",
      "retry_policy": "none"
    }
  ],
  "auth": {
    "method": "none"
  },
  "observability_hooks": ["fastapi_middleware"],
  "rate_limit_defaults": {"rps": 2000, "burst": 4000},
  "code_style_notes": [
    "The handler class stays framework-free; user wires FastAPI via Depends(get_handler) inside a path operation.",
    "FastAPI parses the request body via Pydantic; pass the validated dict to handle().",
    "Raise fastapi.HTTPException from the wrapping route, never inside handle() itself."
  ],
  "allowed_doc_origins": [
    "https://fastapi.tiangolo.com/"
  ]
}
