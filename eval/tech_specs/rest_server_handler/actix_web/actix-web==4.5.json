{
  "schema_version": "v1",
  "category": "rest_server_handler",
  "technology": "actix_web",
  "version_pin": "actix-web==4.5.0",
  "language": "rust",
  "install": {"manager": "cargo", "package": "actix-web==4.5"},
  "imports": {
    "primary": "use actix_web::{web, HttpResponse, Responder};",
    "types": ["use serde_json::Value;"]
  },
  "client_construction": {
    "code": "let _ = ();",
    "is_async": true,
    "thread_safe": true,
    "dependencies": []
  },
  "primary_operations": [
    {
      "name": "handle",
      "signature": "(payload: web::Json<Value>) -> impl Responder",
      "sdk_call": "HttpResponse::Ok().json(payload.into_inner())",
      "error_types": ["actix_web::Error"],
      "idempotency": "non_idempotent",
      "retry_policy": "none"
    }
  ],
  "auth": {"method": "none"},
  "code_style_notes": [
    "App::new().route(\"/\", web::post().to(handle)) registers the handler",
    "actix-web manages its own runtime; do not nest with #[tokio::main]"
  ],
  "allowed_doc_origins": ["https://docs.rs/actix-web/"]
}
