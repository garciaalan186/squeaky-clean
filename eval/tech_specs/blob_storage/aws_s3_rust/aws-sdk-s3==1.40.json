{
  "schema_version": "v1",
  "category": "blob_storage",
  "technology": "aws_s3_rust",
  "version_pin": "aws-sdk-s3==1.40.0",
  "language": "rust",
  "install": {"manager": "cargo", "package": "aws-sdk-s3==1.40"},
  "imports": {
    "primary": "use aws_sdk_s3::Client;",
    "types": ["use aws_sdk_s3::primitives::ByteStream;"]
  },
  "client_construction": {
    "code": "let config = aws_config::load_from_env().await; let client = Client::new(&config);",
    "is_async": true,
    "thread_safe": true,
    "dependencies": ["bucket"]
  },
  "primary_operations": [
    {
      "name": "put_blob",
      "signature": "(key: &str, body: Vec<u8>) -> Result<(), aws_sdk_s3::Error>",
      "sdk_call": "self.client.put_object().bucket(&self.bucket).key(key).body(ByteStream::from(body)).send().await?; Ok(())",
      "error_types": ["aws_sdk_s3::Error"],
      "idempotency": "idempotent",
      "retry_policy": "exponential_backoff(max=3)"
    },
    {
      "name": "get_blob",
      "signature": "(key: &str) -> Result<Vec<u8>, aws_sdk_s3::Error>",
      "sdk_call": "let out = self.client.get_object().bucket(&self.bucket).key(key).send().await?; let bytes = out.body.collect().await.unwrap_or_default().into_bytes().to_vec(); Ok(bytes)",
      "error_types": ["aws_sdk_s3::Error"],
      "idempotency": "idempotent",
      "retry_policy": "exponential_backoff(max=3)"
    },
    {
      "name": "delete_blob",
      "signature": "(key: &str) -> Result<(), aws_sdk_s3::Error>",
      "sdk_call": "self.client.delete_object().bucket(&self.bucket).key(key).send().await?; Ok(())",
      "error_types": ["aws_sdk_s3::Error"],
      "idempotency": "idempotent",
      "retry_policy": "exponential_backoff(max=3)"
    }
  ],
  "auth": {"method": "env_credentials", "env_vars": ["AWS_ACCESS_KEY_ID", "AWS_SECRET_ACCESS_KEY", "AWS_REGION"]},
  "code_style_notes": [
    "aws_config::load_from_env walks env vars + ~/.aws automatically",
    "ByteStream::from is the idiomatic body wrapper"
  ],
  "allowed_doc_origins": ["https://docs.rs/aws-sdk-s3/"]
}
