{
  "schema_version": "v1",
  "category": "secrets_provider",
  "technology": "aws_secrets_manager_go",
  "version_pin": "aws-sdk-go-v2-secretsmanager==1.30.0",
  "language": "go",
  "install": {"manager": "go", "package": "github.com/aws/aws-sdk-go-v2/service/secretsmanager@v1.30.0"},
  "imports": {
    "primary": "\"github.com/aws/aws-sdk-go-v2/service/secretsmanager\"",
    "types": ["\"context\"", "\"github.com/aws/aws-sdk-go-v2/config\"", "\"github.com/aws/aws-sdk-go-v2/aws\""]
  },
  "client_construction": {
    "code": "cfg, _ := config.LoadDefaultConfig(context.Background()); client := secretsmanager.NewFromConfig(cfg)",
    "is_async": false,
    "thread_safe": true,
    "dependencies": []
  },
  "primary_operations": [
    {
      "name": "GetSecret",
      "signature": "(name string) (string, error)",
      "sdk_call": "out, err := s.client.GetSecretValue(context.Background(), &secretsmanager.GetSecretValueInput{SecretId: aws.String(name)}); if err != nil { return \"\", err }; return aws.ToString(out.SecretString), nil",
      "error_types": ["*types.ResourceNotFoundException", "*aws.RequestError"],
      "idempotency": "idempotent",
      "retry_policy": "exponential_backoff(max=3)"
    }
  ],
  "auth": {"method": "iam_role", "env_vars": ["AWS_REGION"]},
  "code_style_notes": [
    "GetSecretValue may return SecretBinary instead of SecretString — handle both",
    "Caching secrets at process boot reduces AWS API quota usage"
  ],
  "allowed_doc_origins": ["https://aws.github.io/aws-sdk-go-v2/"]
}
