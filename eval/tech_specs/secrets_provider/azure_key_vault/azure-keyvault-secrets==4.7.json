{
  "schema_version": "v1",
  "category": "secrets_provider",
  "technology": "azure_key_vault",
  "version_pin": "azure-keyvault-secrets==4.7",
  "language": "python",
  "install": {"manager": "pip", "package": "azure-keyvault-secrets>=4.7"},
  "imports": {
    "primary": "from azure.keyvault.secrets import SecretClient",
    "types":   ["from azure.identity import DefaultAzureCredential", "from azure.core.exceptions import AzureError"]
  },
  "client_construction": {
    "code": "self._client = SecretClient(vault_url=vault_url, credential=DefaultAzureCredential())",
    "is_async": false,
    "thread_safe": true,
    "dependencies": ["vault_url"]
  },
  "primary_operations": [
    {
      "name": "get_secret",
      "signature": "(name: str) -> str",
      "sdk_call": "return self._client.get_secret(name).value",
      "error_types": ["AzureError"],
      "idempotency": "idempotent",
      "retry_policy": "exponential_backoff(max=3)"
    },
    {
      "name": "put_secret",
      "signature": "(name: str, value: str) -> None",
      "sdk_call": "self._client.set_secret(name, value)",
      "error_types": ["AzureError"],
      "idempotency": "idempotent",
      "retry_policy": "exponential_backoff(max=3)"
    }
  ],
  "auth": {
    "method": "env_credentials",
    "env_vars": ["AZURE_CLIENT_ID", "AZURE_CLIENT_SECRET", "AZURE_TENANT_ID"]
  },
  "observability_hooks": ["azure_monitor_compatible"],
  "rate_limit_defaults": {"rps": 200, "burst": 400},
  "code_style_notes": [
    "DefaultAzureCredential walks env, managed identity, and CLI in order; avoid per-call new instances.",
    "set_secret creates a new version; soft-deleted secrets must be purged before name reuse.",
    "SecretClient is thread-safe but should be reused per vault URL."
  ],
  "allowed_doc_origins": [
    "https://learn.microsoft.com/en-us/python/api/overview/azure/keyvault-secrets-readme",
    "https://learn.microsoft.com/en-us/azure/key-vault/"
  ]
}
