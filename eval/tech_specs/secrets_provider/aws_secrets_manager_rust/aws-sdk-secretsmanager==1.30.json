{
  "schema_version": "v1",
  "category": "secrets_provider",
  "technology": "aws_secrets_manager_rust",
  "version_pin": "aws-sdk-secretsmanager==1.30.0",
  "language": "rust",
  "install": {"manager": "cargo", "package": "aws-sdk-secretsmanager==1.30"},
  "imports": {
    "primary": "use aws_sdk_secretsmanager::Client;",
    "types": []
  },
  "client_construction": {
    "code": "let config = aws_config::load_from_env().await; let client = Client::new(&config);",
    "is_async": true,
    "thread_safe": true,
    "dependencies": []
  },
  "primary_operations": [
    {
      "name": "get_secret",
      "signature": "(key: &str) -> Result<String, aws_sdk_secretsmanager::Error>",
      "sdk_call": "let out = self.client.get_secret_value().secret_id(key).send().await?; Ok(out.secret_string().unwrap_or(\"\").to_string())",
      "error_types": ["aws_sdk_secretsmanager::Error"],
      "idempotency": "idempotent",
      "retry_policy": "exponential_backoff(max=3)"
    }
  ],
  "auth": {"method": "env_credentials", "env_vars": ["AWS_ACCESS_KEY_ID", "AWS_SECRET_ACCESS_KEY", "AWS_REGION"]},
  "code_style_notes": [
    "secret_string returns Option<&str>; binary secrets exposed via secret_binary"
  ],
  "allowed_doc_origins": ["https://docs.rs/aws-sdk-secretsmanager/"]
}
