{
  "schema_version": "v1",
  "category": "observability_logger",
  "technology": "pino_ts",
  "version_pin": "pino==8.19.0",
  "language": "typescript",
  "install": {
    "manager": "npm",
    "package": "pino@^8.19.0"
  },
  "imports": {
    "primary": "import pino, { Logger as PinoLogger } from 'pino';",
    "types": []
  },
  "client_construction": {
    "code": "this._logger = pino();",
    "is_async": false,
    "thread_safe": true,
    "dependencies": []
  },
  "primary_operations": [
    {
      "name": "info",
      "signature": "(message: string, context: Record<string, unknown>): void",
      "sdk_call": "this._logger.info(context, message);",
      "error_types": [
        "Error"
      ],
      "idempotency": "idempotent",
      "retry_policy": "none"
    },
    {
      "name": "error",
      "signature": "(message: string, context: Record<string, unknown>): void",
      "sdk_call": "this._logger.error(context, message);",
      "error_types": [
        "Error"
      ],
      "idempotency": "idempotent",
      "retry_policy": "none"
    }
  ],
  "auth": {
    "method": "none"
  },
  "code_style_notes": [
    "pino ships its own .d.ts"
  ],
  "allowed_doc_origins": [
    "https://getpino.io/"
  ]
}
