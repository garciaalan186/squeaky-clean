{
  "schema_version": "v1",
  "category": "websocket_server_handler",
  "technology": "axum_ws",
  "version_pin": "axum==0.7.0",
  "language": "rust",
  "install": {"manager": "cargo", "package": "axum==0.7"},
  "imports": {
    "primary": "use axum::extract::ws::{Message, WebSocket, WebSocketUpgrade};",
    "types": ["use axum::response::Response;"]
  },
  "client_construction": {
    "code": "let _ = ();",
    "is_async": true,
    "thread_safe": true,
    "dependencies": []
  },
  "primary_operations": [
    {
      "name": "handle",
      "signature": "(ws: WebSocketUpgrade) -> Response",
      "sdk_call": "ws.on_upgrade(|mut socket: WebSocket| async move { while let Some(Ok(msg)) = socket.recv().await { if let Message::Text(t) = msg { let _ = socket.send(Message::Text(t)).await; } } })",
      "error_types": ["axum::Error"],
      "idempotency": "non_idempotent",
      "retry_policy": "none"
    }
  ],
  "auth": {"method": "none"},
  "code_style_notes": [
    "axum's ws feature must be enabled in Cargo.toml",
    "WebSocketUpgrade returns Response after on_upgrade"
  ],
  "allowed_doc_origins": ["https://docs.rs/axum/"]
}
