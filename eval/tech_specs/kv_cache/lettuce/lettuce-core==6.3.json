{
  "schema_version": "v1",
  "category": "kv_cache",
  "technology": "lettuce",
  "version_pin": "lettuce-core==6.3",
  "language": "java",
  "install": {"manager": "maven", "package": "io.lettuce:lettuce-core:6.3.2.RELEASE"},
  "imports": {
    "primary": "import io.lettuce.core.RedisClient;",
    "types": [
      "import io.lettuce.core.api.StatefulRedisConnection;",
      "import io.lettuce.core.api.sync.RedisCommands;",
      "import io.lettuce.core.RedisException;"
    ]
  },
  "client_construction": {
    "code": "this.client = RedisClient.create(uri); this.connection = this.client.connect(); this.commands = this.connection.sync();",
    "is_async": false,
    "thread_safe": true,
    "dependencies": ["uri"]
  },
  "primary_operations": [
    {
      "name": "set",
      "signature": "(String key, String value)",
      "sdk_call": "this.commands.set(key, value);",
      "error_types": ["RedisException"],
      "idempotency": "idempotent",
      "retry_policy": "exponential_backoff(max=3)"
    },
    {
      "name": "get",
      "signature": "(String key)",
      "sdk_call": "return this.commands.get(key);",
      "error_types": ["RedisException"],
      "idempotency": "idempotent",
      "retry_policy": "exponential_backoff(max=3)"
    },
    {
      "name": "expire",
      "signature": "(String key, long seconds)",
      "sdk_call": "this.commands.expire(key, seconds);",
      "error_types": ["RedisException"],
      "idempotency": "idempotent",
      "retry_policy": "none"
    },
    {
      "name": "delete",
      "signature": "(String key)",
      "sdk_call": "this.commands.del(key);",
      "error_types": ["RedisException"],
      "idempotency": "idempotent",
      "retry_policy": "exponential_backoff(max=3)"
    }
  ],
  "auth": {
    "method": "env_credentials",
    "env_vars": ["REDIS_URL"]
  },
  "observability_hooks": ["micrometer-lettuce"],
  "rate_limit_defaults": {"rps": 80000, "burst": 200000},
  "code_style_notes": [
    "RedisClient is thread-safe; share one instance and one connection across threads.",
    "Lettuce supports sync, async, and reactive APIs from the same connection.",
    "Always shutdown the RedisClient on application exit."
  ],
  "allowed_doc_origins": ["https://lettuce.io/core/release/reference/"]
}
