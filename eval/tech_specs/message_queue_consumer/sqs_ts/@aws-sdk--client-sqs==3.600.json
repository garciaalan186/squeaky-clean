{
  "schema_version": "v1",
  "category": "message_queue_consumer",
  "technology": "sqs_ts",
  "version_pin": "@aws-sdk/client-sqs==3.600.0",
  "language": "typescript",
  "install": {
    "manager": "npm",
    "package": "@aws-sdk/client-sqs@^3.600.0"
  },
  "imports": {
    "primary": "import { SQSClient, ReceiveMessageCommand } from '@aws-sdk/client-sqs';",
    "types": []
  },
  "client_construction": {
    "code": "this._client = new SQSClient({}); this._queueUrl = queueUrl;",
    "is_async": false,
    "thread_safe": true,
    "dependencies": [
      "queueUrl"
    ]
  },
  "primary_operations": [
    {
      "name": "consumeRaw",
      "signature": "(): Promise<Buffer | null>",
      "sdk_call": "const r = await this._client.send(new ReceiveMessageCommand({ QueueUrl: this._queueUrl, MaxNumberOfMessages: 1, WaitTimeSeconds: 5 })); const m = (r.Messages ?? [])[0]; return m ? Buffer.from(m.Body ?? '') : null;",
      "error_types": [
        "SQSServiceException"
      ],
      "idempotency": "non_idempotent",
      "retry_policy": "exponential_backoff(max=3)"
    }
  ],
  "auth": {
    "method": "env_credentials",
    "env_vars": [
      "AWS_ACCESS_KEY_ID",
      "AWS_SECRET_ACCESS_KEY",
      "AWS_REGION"
    ]
  },
  "code_style_notes": [
    "aws-sdk-js v3 ships TS types"
  ],
  "allowed_doc_origins": [
    "https://docs.aws.amazon.com/AWSJavaScriptSDK/v3/"
  ]
}
