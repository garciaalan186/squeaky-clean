{
  "schema_version": "v1",
  "category": "message_queue_consumer",
  "technology": "spring_kafka",
  "version_pin": "spring-kafka==3.1",
  "language": "java",
  "install": {"manager": "maven", "package": "org.springframework.kafka:spring-kafka:3.1.0"},
  "imports": {
    "primary": "import org.springframework.kafka.annotation.KafkaListener;",
    "types": [
      "import com.fasterxml.jackson.databind.ObjectMapper;",
      "import java.io.IOException;"
    ]
  },
  "client_construction": {
    "code": "this.useCase = useCase; this.objectMapper = new ObjectMapper();",
    "is_async": false,
    "thread_safe": false,
    "dependencies": ["use_case"]
  },
  "primary_operations": [
    {
      "name": "consume",
      "signature": "(String message)",
      "sdk_call": "java.util.Map<String, Object> parsed = this.objectMapper.readValue(message, java.util.Map.class);\nthis.useCase.execute(parsed);",
      "error_types": ["IOException", "RuntimeException"],
      "idempotency": "non_idempotent",
      "retry_policy": "none"
    }
  ],
  "auth": {
    "method": "env_credentials",
    "env_vars": ["KAFKA_BOOTSTRAP_SERVERS", "KAFKA_GROUP_ID", "KAFKA_TOPIC", "KAFKA_SASL_USERNAME", "KAFKA_SASL_PASSWORD"]
  },
  "observability_hooks": ["spring_actuator", "micrometer_kafka_metrics"],
  "rate_limit_defaults": {"rps": 50000, "burst": 100000},
  "code_style_notes": [
    "Annotate the consume method with @KafkaListener(topics = \"<topic>\", groupId = \"<group>\").",
    "Spring auto-configures consumer factory via spring.kafka.consumer.* properties.",
    "Use Jackson ObjectMapper.readValue to deserialize the payload to a Map or domain object.",
    "Class is plain (no @Component); enable via @EnableKafka in the @SpringBootApplication."
  ],
  "allowed_doc_origins": [
    "https://docs.spring.io/spring-kafka/reference/",
    "https://kafka.apache.org/documentation/"
  ]
}
