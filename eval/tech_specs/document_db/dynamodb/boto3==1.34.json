{
  "schema_version": "v1",
  "category": "document_db",
  "technology": "dynamodb",
  "version_pin": "boto3==1.34",
  "language": "python",
  "install": {"manager": "pip", "package": "boto3==1.34"},
  "imports": {
    "primary": "import boto3",
    "types":   ["from botocore.exceptions import ClientError, EndpointConnectionError"]
  },
  "client_construction": {
    "code": "self._table = boto3.resource('dynamodb', region_name=region).Table(table_name)",
    "is_async": false,
    "thread_safe": false,
    "dependencies": ["region", "table_name"]
  },
  "primary_operations": [
    {
      "name": "save",
      "signature": "(entity_id: str, payload: bytes) -> None",
      "sdk_call": "self._table.put_item(Item={'id': entity_id, 'payload': payload})",
      "error_types": ["ClientError", "EndpointConnectionError"],
      "idempotency": "idempotent",
      "retry_policy": "exponential_backoff(max=3)"
    },
    {
      "name": "find_by_id",
      "signature": "(entity_id: str) -> bytes",
      "sdk_call": "resp = self._table.get_item(Key={'id': entity_id}); return bytes(resp['Item']['payload'])",
      "error_types": ["ClientError", "EndpointConnectionError"],
      "idempotency": "idempotent",
      "retry_policy": "exponential_backoff(max=3)"
    },
    {
      "name": "upsert",
      "signature": "(entity_id: str, payload: bytes) -> None",
      "sdk_call": "self._table.update_item(Key={'id': entity_id}, UpdateExpression='SET payload = :p', ExpressionAttributeValues={':p': payload})",
      "error_types": ["ClientError", "EndpointConnectionError"],
      "idempotency": "idempotent",
      "retry_policy": "exponential_backoff(max=3)"
    }
  ],
  "auth": {
    "method": "iam_role",
    "env_vars": ["AWS_ACCESS_KEY_ID", "AWS_SECRET_ACCESS_KEY", "AWS_DEFAULT_REGION"]
  },
  "observability_hooks": ["aws-xray-compatible"],
  "rate_limit_defaults": {"rps": 4000, "burst": 8000},
  "code_style_notes": [
    "boto3 resource clients are NOT thread-safe; instantiate per-thread or use the low-level client",
    "DynamoDB partition keys are case-sensitive strings; payload bytes go in a Binary attribute",
    "ClientError.response['Error']['Code'] = 'ResourceNotFoundException' for missing items"
  ],
  "allowed_doc_origins": [
    "https://boto3.amazonaws.com/v1/documentation/api/latest/reference/services/dynamodb.html",
    "https://docs.aws.amazon.com/amazondynamodb/"
  ]
}
