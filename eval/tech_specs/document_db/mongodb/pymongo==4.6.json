{
  "schema_version": "v1",
  "category": "document_db",
  "technology": "mongodb",
  "version_pin": "pymongo==4.6",
  "language": "python",
  "install": {"manager": "pip", "package": "pymongo>=4.6"},
  "imports": {
    "primary": "from pymongo import MongoClient",
    "types":   ["from pymongo.errors import PyMongoError, DuplicateKeyError"]
  },
  "client_construction": {
    "code": "self._collection = MongoClient(uri)[db_name]['entities']",
    "is_async": false,
    "thread_safe": true,
    "dependencies": ["uri", "db_name"]
  },
  "primary_operations": [
    {
      "name": "save",
      "signature": "(entity_id: str, payload: bytes) -> None",
      "sdk_call": "self._collection.replace_one({'_id': entity_id}, {'_id': entity_id, 'payload': payload}, upsert=True)",
      "error_types": ["PyMongoError", "DuplicateKeyError"],
      "idempotency": "idempotent",
      "retry_policy": "exponential_backoff(max=3)"
    },
    {
      "name": "find_by_id",
      "signature": "(entity_id: str) -> bytes",
      "sdk_call": "doc = self._collection.find_one({'_id': entity_id}); return bytes(doc['payload'])",
      "error_types": ["PyMongoError"],
      "idempotency": "idempotent",
      "retry_policy": "exponential_backoff(max=3)"
    },
    {
      "name": "upsert",
      "signature": "(entity_id: str, payload: bytes) -> None",
      "sdk_call": "self._collection.update_one({'_id': entity_id}, {'$set': {'payload': payload}}, upsert=True)",
      "error_types": ["PyMongoError"],
      "idempotency": "idempotent",
      "retry_policy": "exponential_backoff(max=3)"
    }
  ],
  "auth": {
    "method": "env_credentials",
    "env_vars": ["MONGODB_URI", "MONGODB_USER", "MONGODB_PASSWORD"]
  },
  "observability_hooks": ["opentelemetry_pymongo_instrumentation"],
  "rate_limit_defaults": {"rps": 10000, "burst": 20000},
  "code_style_notes": [
    "MongoClient is fork-safe and thread-safe; instantiate ONCE per process",
    "use replace_one(..., upsert=True) for full-document upsert; update_one with $set for partial",
    "BSON _id field is the primary key; supplying it explicitly avoids server-generated ObjectId"
  ],
  "allowed_doc_origins": [
    "https://pymongo.readthedocs.io/en/stable/",
    "https://www.mongodb.com/docs/"
  ]
}
