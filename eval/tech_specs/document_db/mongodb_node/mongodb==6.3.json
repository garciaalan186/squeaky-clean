{
  "schema_version": "v1",
  "category": "document_db",
  "technology": "mongodb_node",
  "version_pin": "mongodb==6.3.0",
  "language": "javascript",
  "install": {
    "manager": "npm",
    "package": "mongodb@^6.3.0"
  },
  "imports": {
    "primary": "import { MongoClient } from 'mongodb';",
    "types": []
  },
  "client_construction": {
    "code": "this._client = new MongoClient(uri); this._collection = this._client.db(dbName).collection('records');",
    "is_async": false,
    "thread_safe": true,
    "dependencies": [
      "uri",
      "dbName"
    ]
  },
  "primary_operations": [
    {
      "name": "save",
      "signature": "(doc: Record<string, unknown>): Promise<void>",
      "sdk_call": "await this._collection.updateOne({ _id: doc.id }, { $set: doc }, { upsert: true });",
      "error_types": [
        "MongoServerError"
      ],
      "idempotency": "idempotent",
      "retry_policy": "none"
    },
    {
      "name": "findById",
      "signature": "(id: string): Promise<Record<string, unknown> | null>",
      "sdk_call": "return await this._collection.findOne({ _id: id });",
      "error_types": [
        "MongoServerError"
      ],
      "idempotency": "idempotent",
      "retry_policy": "none"
    }
  ],
  "auth": {
    "method": "static_keys",
    "env_vars": [
      "MONGODB_URI"
    ]
  },
  "code_style_notes": [
    "call client.connect() if you need to await readiness"
  ],
  "allowed_doc_origins": [
    "https://www.mongodb.com/docs/drivers/node/current/"
  ]
}
