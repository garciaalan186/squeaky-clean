{
  "schema_version": "v1",
  "category": "stream_processor",
  "technology": "kafkajs_stream",
  "version_pin": "kafkajs==2.2.4",
  "language": "javascript",
  "install": {
    "manager": "npm",
    "package": "kafkajs@^2.2.4"
  },
  "imports": {
    "primary": "import { Kafka } from 'kafkajs';",
    "types": []
  },
  "client_construction": {
    "code": "this._kafka = new Kafka({ brokers: brokers.split(',') }); this._consumer = this._kafka.consumer({ groupId }); this._topic = topic;",
    "is_async": false,
    "thread_safe": true,
    "dependencies": [
      "brokers",
      "topic",
      "groupId"
    ]
  },
  "primary_operations": [
    {
      "name": "processStream",
      "signature": "(handler: (msg: Buffer) => Promise<void>): Promise<void>",
      "sdk_call": "await this._consumer.connect(); await this._consumer.subscribe({ topic: this._topic, fromBeginning: false }); await this._consumer.run({ eachMessage: async ({ message }) => handler(message.value) });",
      "error_types": [
        "KafkaJSError"
      ],
      "idempotency": "non_idempotent",
      "retry_policy": "exponential_backoff(max=3)"
    }
  ],
  "auth": {
    "method": "static_keys",
    "env_vars": [
      "KAFKA_BOOTSTRAP_SERVERS",
      "KAFKA_GROUP_ID",
      "KAFKA_TOPIC"
    ]
  },
  "code_style_notes": [
    "consumer.run owns the long-poll loop"
  ],
  "allowed_doc_origins": [
    "https://kafka.js.org/"
  ]
}
