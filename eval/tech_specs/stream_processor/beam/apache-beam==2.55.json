{
  "schema_version": "v1",
  "category": "stream_processor",
  "technology": "beam",
  "version_pin": "apache-beam==2.55",
  "language": "python",
  "install": {"manager": "pip", "package": "apache-beam>=2.55"},
  "imports": {
    "primary": "import apache_beam",
    "types":   ["from apache_beam import Pipeline, PTransform", "from apache_beam.options.pipeline_options import PipelineOptions"]
  },
  "client_construction": {
    "code": "self._pipeline = apache_beam.Pipeline(options=PipelineOptions([f'--job_name={job_name}']))",
    "is_async": false,
    "thread_safe": false,
    "dependencies": ["job_name"]
  },
  "primary_operations": [
    {
      "name": "process",
      "signature": "(record: bytes) -> bytes",
      "sdk_call": "return record",
      "error_types": ["RuntimeError"],
      "idempotency": "idempotent",
      "retry_policy": "none"
    },
    {
      "name": "aggregate",
      "signature": "(window_seconds: int) -> bytes",
      "sdk_call": "return b''",
      "error_types": ["RuntimeError"],
      "idempotency": "non_idempotent",
      "retry_policy": "none"
    },
    {
      "name": "window",
      "signature": "(window_seconds: int) -> bytes",
      "sdk_call": "return b''",
      "error_types": ["RuntimeError"],
      "idempotency": "non_idempotent",
      "retry_policy": "none"
    }
  ],
  "auth": {
    "method": "none"
  },
  "observability_hooks": ["beam_metric_reporter_prometheus"],
  "rate_limit_defaults": {"rps": 50000, "burst": 100000},
  "code_style_notes": [
    "Beam pipelines are deferred — pipeline.run() launches against a runner (Direct, Dataflow, Flink, Spark)",
    "Pipeline objects are NOT thread-safe; build the topology on the main thread, run from any",
    "use beam.io.WriteToText, ReadFromPubSub, etc. for source/sink transforms"
  ],
  "allowed_doc_origins": [
    "https://beam.apache.org/documentation/sdks/python/",
    "https://beam.apache.org/"
  ]
}
