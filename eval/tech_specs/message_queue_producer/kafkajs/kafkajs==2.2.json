{
  "schema_version": "v1",
  "category": "message_queue_producer",
  "technology": "kafkajs",
  "version_pin": "kafkajs==2.2.4",
  "language": "javascript",
  "install": {
    "manager": "npm",
    "package": "kafkajs@^2.2.4"
  },
  "imports": {
    "primary": "import { Kafka } from 'kafkajs';",
    "types": []
  },
  "client_construction": {
    "code": "this._kafka = new Kafka({ brokers: brokers.split(',') }); this._producer = this._kafka.producer();",
    "is_async": false,
    "thread_safe": true,
    "dependencies": [
      "brokers"
    ]
  },
  "primary_operations": [
    {
      "name": "publishEvent",
      "signature": "(topic: string, payload: Buffer): Promise<void>",
      "sdk_call": "await this._producer.connect(); await this._producer.send({ topic, messages: [{ value: payload }] });",
      "error_types": [
        "KafkaJSError"
      ],
      "idempotency": "non_idempotent",
      "retry_policy": "exponential_backoff(max=3)"
    }
  ],
  "auth": {
    "method": "static_keys",
    "env_vars": [
      "KAFKA_BOOTSTRAP_SERVERS",
      "KAFKA_USERNAME",
      "KAFKA_PASSWORD"
    ]
  },
  "code_style_notes": [
    "call producer.connect() before first send"
  ],
  "allowed_doc_origins": [
    "https://kafka.js.org/"
  ]
}
