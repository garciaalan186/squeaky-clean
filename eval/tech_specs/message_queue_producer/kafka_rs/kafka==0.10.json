{
  "schema_version": "v1",
  "category": "message_queue_producer",
  "technology": "kafka_rs",
  "version_pin": "kafka==0.10.0",
  "language": "rust",
  "install": {"manager": "cargo", "package": "kafka==0.10"},
  "imports": {
    "primary": "use kafka::producer::{Producer, Record, RequiredAcks};",
    "types": []
  },
  "client_construction": {
    "code": "let producer = Producer::from_hosts(vec![brokers.to_string()]).with_ack_timeout(std::time::Duration::from_secs(1)).with_required_acks(RequiredAcks::One).create()?;",
    "is_async": false,
    "thread_safe": false,
    "dependencies": ["brokers"]
  },
  "primary_operations": [
    {
      "name": "publish_event",
      "signature": "(topic: &str, payload: &[u8]) -> Result<(), kafka::Error>",
      "sdk_call": "self.producer.send(&Record::from_value(topic, payload))",
      "error_types": ["kafka::Error"],
      "idempotency": "non_idempotent",
      "retry_policy": "exponential_backoff(max=3)"
    }
  ],
  "auth": {"method": "static_keys", "env_vars": ["KAFKA_BOOTSTRAP_SERVERS"]},
  "code_style_notes": [
    "kafka crate is pure Rust (no librdkafka dependency) but synchronous",
    "wrap calls in tokio::task::spawn_blocking when used inside async runtime"
  ],
  "allowed_doc_origins": ["https://docs.rs/kafka/"]
}
