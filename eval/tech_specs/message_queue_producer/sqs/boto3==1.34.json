{
  "schema_version": "v1",
  "category": "message_queue_producer",
  "technology": "sqs",
  "version_pin": "boto3==1.34",
  "language": "python",
  "install": {"manager": "pip", "package": "boto3==1.34"},
  "imports": {
    "primary": "import boto3",
    "types":   ["from botocore.exceptions import ClientError, EndpointConnectionError"]
  },
  "client_construction": {
    "code": "self._client = boto3.client('sqs', region_name=region)",
    "is_async": false,
    "thread_safe": false,
    "dependencies": ["region", "queue_url"]
  },
  "primary_operations": [
    {
      "name": "send",
      "signature": "(queue_url: str, payload: bytes) -> None",
      "sdk_call": "self._client.send_message(QueueUrl=queue_url, MessageBody=payload.decode('utf-8'))",
      "error_types": ["ClientError", "EndpointConnectionError"],
      "idempotency": "non_idempotent",
      "retry_policy": "exponential_backoff(max=3)"
    },
    {
      "name": "publish",
      "signature": "(queue_url: str, payload: bytes) -> None",
      "sdk_call": "self._client.send_message(QueueUrl=queue_url, MessageBody=payload.decode('utf-8'))",
      "error_types": ["ClientError", "EndpointConnectionError"],
      "idempotency": "non_idempotent",
      "retry_policy": "exponential_backoff(max=3)"
    }
  ],
  "auth": {
    "method": "iam_role",
    "env_vars": ["AWS_ACCESS_KEY_ID", "AWS_SECRET_ACCESS_KEY", "AWS_DEFAULT_REGION"]
  },
  "observability_hooks": ["aws-xray-compatible"],
  "rate_limit_defaults": {"rps": 3000, "burst": 6000},
  "code_style_notes": [
    "boto3 SQS clients are NOT thread-safe; instantiate per-thread",
    "MessageBody must be a UTF-8 string; binary payloads need base64 + MessageAttributes",
    "FIFO queues require MessageGroupId; standard queues do not"
  ],
  "allowed_doc_origins": [
    "https://boto3.amazonaws.com/v1/documentation/api/latest/reference/services/sqs.html",
    "https://docs.aws.amazon.com/AWSSimpleQueueService/"
  ]
}
