{
  "schema_version": "v1",
  "category": "message_queue_producer",
  "technology": "kafka",
  "version_pin": "confluent-kafka==2.5",
  "language": "python",
  "install": {"manager": "pip", "package": "confluent-kafka>=2.5"},
  "imports": {
    "primary": "from confluent_kafka import Producer",
    "types":   ["from confluent_kafka.error import KafkaException, KafkaError"]
  },
  "client_construction": {
    "code": "self._producer = Producer({'bootstrap.servers': bootstrap_servers})",
    "is_async": false,
    "thread_safe": true,
    "dependencies": ["bootstrap_servers"]
  },
  "primary_operations": [
    {
      "name": "publish",
      "signature": "(topic: str, payload: bytes) -> None",
      "sdk_call": "self._producer.produce(topic, payload)",
      "error_types": ["KafkaException", "KafkaError"],
      "idempotency": "non_idempotent",
      "retry_policy": "exponential_backoff(max=3)"
    },
    {
      "name": "flush",
      "signature": "(timeout: float) -> None",
      "sdk_call": "self._producer.flush(timeout)",
      "error_types": ["KafkaException"],
      "idempotency": "idempotent",
      "retry_policy": "none"
    }
  ],
  "auth": {
    "method": "env_credentials",
    "env_vars": ["KAFKA_BOOTSTRAP_SERVERS", "KAFKA_SASL_USERNAME", "KAFKA_SASL_PASSWORD"]
  },
  "observability_hooks": ["opentelemetry_kafka_instrumentation"],
  "rate_limit_defaults": {"rps": 100000, "burst": 200000},
  "code_style_notes": [
    "Producer is thread-safe; share a single instance across producer threads",
    "always call flush() before process exit — buffered records are lost otherwise",
    "produce() is async by default; pass on_delivery callback to detect broker errors"
  ],
  "allowed_doc_origins": [
    "https://docs.confluent.io/platform/current/clients/confluent-kafka-python/",
    "https://kafka.apache.org/documentation/"
  ]
}
