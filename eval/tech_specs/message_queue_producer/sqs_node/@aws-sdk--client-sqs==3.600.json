{
  "schema_version": "v1",
  "category": "message_queue_producer",
  "technology": "sqs_node",
  "version_pin": "@aws-sdk/client-sqs==3.600.0",
  "language": "javascript",
  "install": {
    "manager": "npm",
    "package": "@aws-sdk/client-sqs@^3.600.0"
  },
  "imports": {
    "primary": "import { SQSClient, SendMessageCommand } from '@aws-sdk/client-sqs';",
    "types": []
  },
  "client_construction": {
    "code": "this._client = new SQSClient({}); this._queueUrl = queueUrl;",
    "is_async": false,
    "thread_safe": true,
    "dependencies": [
      "queueUrl"
    ]
  },
  "primary_operations": [
    {
      "name": "publishEvent",
      "signature": "(topic: string, payload: Buffer): Promise<void>",
      "sdk_call": "await this._client.send(new SendMessageCommand({ QueueUrl: this._queueUrl, MessageBody: payload.toString() }));",
      "error_types": [
        "SQSServiceException"
      ],
      "idempotency": "non_idempotent",
      "retry_policy": "exponential_backoff(max=3)"
    }
  ],
  "auth": {
    "method": "env_credentials",
    "env_vars": [
      "AWS_ACCESS_KEY_ID",
      "AWS_SECRET_ACCESS_KEY",
      "AWS_REGION"
    ]
  },
  "code_style_notes": [
    "SQS message body is string; encode binary as base64"
  ],
  "allowed_doc_origins": [
    "https://docs.aws.amazon.com/AWSJavaScriptSDK/v3/"
  ]
}
