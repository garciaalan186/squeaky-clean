{
  "schema_version": "v1",
  "category": "search",
  "technology": "elasticsearch_node",
  "version_pin": "@elastic/elasticsearch==8.13.0",
  "language": "javascript",
  "install": {
    "manager": "npm",
    "package": "@elastic/elasticsearch@^8.13.0"
  },
  "imports": {
    "primary": "import { Client } from '@elastic/elasticsearch';",
    "types": []
  },
  "client_construction": {
    "code": "this._client = new Client({ node }); this._index = indexName;",
    "is_async": false,
    "thread_safe": true,
    "dependencies": [
      "node",
      "indexName"
    ]
  },
  "primary_operations": [
    {
      "name": "index",
      "signature": "(doc: Record<string, unknown>): Promise<void>",
      "sdk_call": "await this._client.index({ index: this._index, document: doc });",
      "error_types": [
        "ResponseError"
      ],
      "idempotency": "idempotent",
      "retry_policy": "exponential_backoff(max=3)"
    },
    {
      "name": "search",
      "signature": "(query: Record<string, unknown>): Promise<unknown[]>",
      "sdk_call": "const r = await this._client.search({ index: this._index, query }); return r.hits.hits;",
      "error_types": [
        "ResponseError"
      ],
      "idempotency": "idempotent",
      "retry_policy": "exponential_backoff(max=3)"
    }
  ],
  "auth": {
    "method": "static_keys",
    "env_vars": [
      "ELASTIC_NODE",
      "ELASTIC_API_KEY"
    ]
  },
  "code_style_notes": [
    "v8 client uses native promises"
  ],
  "allowed_doc_origins": [
    "https://www.elastic.co/guide/en/elasticsearch/client/javascript-api/"
  ]
}
